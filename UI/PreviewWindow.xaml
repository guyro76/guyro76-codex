<Window x:Class="LangFlipDesktop.UI.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="תצוגה מקדימה"
        Width="600"
        Height="500"
        Background="#071426"
        Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <Style x:Key="PreviewTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0F2441" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="16" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>

        <Style x:Key="PreviewButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="120" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#38D5FF" />
                                <Setter Property="Foreground" Value="#000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Orientation="Vertical">
        <!-- Original -->
        <TextBlock Text="המקור:" FontSize="14" FontWeight="Bold" Foreground="#38D5FF" Margin="16,16,16,4" />
        <TextBox x:Name="OriginalTextBox" Style="{StaticResource PreviewTextBox}" Height="150" />

        <!-- Result -->
        <TextBlock Text="התוצאה:" FontSize="14" FontWeight="Bold" Foreground="#38D5FF" Margin="16,16,16,4" />
        <TextBox x:Name="ResultTextBox" Style="{StaticResource PreviewTextBox}" Height="150" />

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,16">
            <Button Content="החלף במקום" Style="{StaticResource PreviewButton}" Click="Button_Replace" />
            <Button Content="העתק" Style="{StaticResource PreviewButton}" Background="#4FFF00" Foreground="#000000" Click="Button_Copy" />
            <Button Content="ביטול" Style="{StaticResource PreviewButton}" Background="#333333" Click="Button_Cancel" />
        </StackPanel>
    </StackPanel>
</Window>
