<Window x:Class="LangFlipDesktop.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="קליקשפה - LangFlip Desktop"
        Width="700"
        Height="900"
        Background="#071426"
        Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="Background" Value="#1E3A5F" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB" />
                                <Setter Property="BorderBrush" Value="#38D5FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusCard" TargetType="Border">
            <Setter Property="Background" Value="#0F2441" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="16" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" Margin="0">
            <!-- Header -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,32,0,0">
                <TextBlock Text="קליקשפה" FontSize="48" FontWeight="Bold" Foreground="#38D5FF" TextAlignment="Center" />
                <TextBlock Text="מתקן, מתרגם ומשפר טקסט בכל מקום במחשב"
                           FontSize="14" Foreground="#BDEFFF" TextAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>

            <!-- Status Card -->
            <Border Style="{StaticResource StatusCard}">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Ellipse Width="12" Height="12" Fill="#4FFF00" Margin="8,0,0,0" />
                        <TextBlock Text="האפליקציה פעילה ברקע" Foreground="#BDEFFF" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Quick Actions -->
            <TextBlock Text="פעולות מהירות" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="16,16,16,8" />
            <WrapPanel HorizontalAlignment="Center" Margin="8">
                <Button Content="הפוך לעברית" Style="{StaticResource GlassButton}" Click="Button_ConvertHebrew" />
                <Button Content="הפוך לאנגלית" Style="{StaticResource GlassButton}" Click="Button_ConvertEnglish" />
                <Button Content="תרגם לאנגלית" Style="{StaticResource GlassButton}" Click="Button_TranslateEnglish" />
                <Button Content="תרגם לעברית" Style="{StaticResource GlassButton}" Click="Button_TranslateHebrew" />
                <Button Content="שפר ניסוח" Style="{StaticResource GlassButton}" Click="Button_Improve" />
            </WrapPanel>

            <!-- Result Mode -->
            <TextBlock Text="מצב תוצאה" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="16,16,16,8" />
            <Border Style="{StaticResource StatusCard}">
                <StackPanel Orientation="Vertical">
                    <RadioButton Content="הצג לפני החלפה" Foreground="#FFFFFF" Margin="8" IsChecked="True" />
                    <RadioButton Content="החלף במקום" Foreground="#FFFFFF" Margin="8" />
                    <RadioButton Content="העתק ללוח בלבד" Foreground="#FFFFFF" Margin="8" />
                </StackPanel>
            </Border>

            <!-- Shortcuts Card -->
            <TextBlock Text="קיצורי דרך" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="16,16,16,8" />
            <Border Style="{StaticResource StatusCard}">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Ctrl + Alt + H — הפוך לעברית" Foreground="#BDEFFF" Margin="8" FontSize="12" />
                    <TextBlock Text="Ctrl + Alt + E — הפוך לאנגלית" Foreground="#BDEFFF" Margin="8" FontSize="12" />
                    <TextBlock Text="Ctrl + Alt + T — תרגום אוטומטי" Foreground="#BDEFFF" Margin="8" FontSize="12" />
                    <TextBlock Text="Ctrl + Alt + I — שיפור ניסוח" Foreground="#BDEFFF" Margin="8" FontSize="12" />
                    <TextBlock Text="Ctrl + Alt + Space — תפריט מהיר" Foreground="#BDEFFF" Margin="8" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Privacy Card -->
            <TextBlock Text="פרטיות וביטחון" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="16,16,16,8" />
            <Border Style="{StaticResource StatusCard}">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="✓ תיקון מקלדת מתבצע מקומית בלבד" Foreground="#4FFF00" Margin="8" FontSize="12" />
                    <TextBlock Text="✓ טקסט לא נשמר כברירת מחדל" Foreground="#4FFF00" Margin="8" FontSize="12" />
                    <TextBlock Text="✓ תרגום שולח רק את הטקסט המסומן" Foreground="#4FFF00" Margin="8" FontSize="12" />
                    <TextBlock Text="✓ לא עובדים על שדות סיסמה" Foreground="#4FFF00" Margin="8" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Settings Button -->
            <Button Content="הגדרות" Style="{StaticResource GlassButton}" Click="Button_Settings"
                    Width="150" HorizontalAlignment="Center" Margin="0,16,0,16" />

            <!-- Copyright Footer -->
            <Border Background="#0B1F4D" BorderBrush="#2563EB" BorderThickness="0,1,0,0" Padding="16,16,16,16" Margin="0,32,0,0">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="קליקשפה v1.0 | עדכון: 11.06.2026"
                               FontSize="13" FontWeight="Bold" Foreground="#38D5FF"
                               TextAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="© נבנה ותוכנן על ידי גיא רוזנברג 2026"
                               FontSize="12" FontWeight="Bold" Foreground="#4FFF00"
                               TextAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="כל הזכויות שמורות ©"
                               FontSize="11" Foreground="#BDEFFF"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
