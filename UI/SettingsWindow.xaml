<Window x:Class="LangFlipDesktop.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="הגדרות - Settings"
        Width="600"
        Height="700"
        Background="#071426"
        Foreground="#FFFFFF"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#38D5FF" />
            <Setter Property="Margin" Value="16,16,16,8" />
        </Style>

        <Style x:Key="SettingCard" TargetType="Border">
            <Setter Property="Background" Value="#0F2441" />
            <Setter Property="BorderBrush" Value="#1E3A5F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="16,8,16,8" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" Margin="0">
            <!-- General Settings -->
            <TextBlock Text="הגדרות כלליות" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SettingCard}">
                <StackPanel Orientation="Vertical">
                    <CheckBox Content="הפעלה עם Windows" Foreground="#FFFFFF" Margin="8" />
                    <CheckBox Content="הרץ ברקע" Foreground="#FFFFFF" Margin="8" IsChecked="True" />
                    <CheckBox Content="הצג אייקון בסרגל המשימות" Foreground="#FFFFFF" Margin="8" IsChecked="True" />
                </StackPanel>
            </Border>

            <!-- Result Behavior -->
            <TextBlock Text="התנהגות התוצאות" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SettingCard}">
                <StackPanel Orientation="Vertical">
                    <RadioButton Content="הצג לפני החלפה" Foreground="#FFFFFF" Margin="8" IsChecked="True" />
                    <RadioButton Content="החלף במקום" Foreground="#FFFFFF" Margin="8" />
                    <RadioButton Content="העתק ללוח בלבד" Foreground="#FFFFFF" Margin="8" />
                    <CheckBox Content="שחזר את תוכן לוח זכרון קודם" Foreground="#FFFFFF" Margin="8" IsChecked="True" />
                </StackPanel>
            </Border>

            <!-- Translation Provider -->
            <TextBlock Text="ספק תרגום" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SettingCard}">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="בחר ספק:" Foreground="#FFFFFF" Margin="8" />
                    <ComboBox Foreground="#000000" Background="#FFFFFF" Margin="8" x:Name="ProviderCombo">
                        <ComboBoxItem Content="אין (בלוקאלי בלבד)" />
                        <ComboBoxItem Content="OpenAI" />
                        <ComboBoxItem Content="DeepL" />
                        <ComboBoxItem Content="Google Cloud" />
                    </ComboBox>

                    <TextBlock Text="API Key:" Foreground="#FFFFFF" Margin="8,8,8,2" />
                    <PasswordBox x:Name="ApiKeyBox" Foreground="#000000" Background="#FFFFFF" Margin="8,2,8,8" />

                    <Button Content="בדוק חיבור" Width="150" Background="#2563EB" Foreground="#FFFFFF"
                            Padding="8" Margin="8" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- Keyboard Shortcuts -->
            <TextBlock Text="קיצורי דרך" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SettingCard}">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="ניתן להתאים קיצורים בגרסה הבאה" Foreground="#BDEFFF" Margin="8" FontSize="12" />
                    <Button Content="אפס לברירות זכות" Width="150" Background="#2563EB" Foreground="#FFFFFF"
                            Padding="8" Margin="8" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- Privacy -->
            <TextBlock Text="פרטיות וביטחון" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SettingCard}">
                <StackPanel Orientation="Vertical">
                    <CheckBox Content="אל תשמור טקסטים" Foreground="#FFFFFF" Margin="8" IsChecked="True" />
                    <CheckBox Content="אל תעבד שדות סיסמה" Foreground="#FFFFFF" Margin="8" IsChecked="True" />
                    <CheckBox Content="תיקון מקלדת מקומי בלבד" Foreground="#FFFFFF" Margin="8" IsChecked="True" />
                    <Button Content="נקה נתונים זמניים" Width="150" Background="#8B0000" Foreground="#FFFFFF"
                            Padding="8" Margin="8" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- Design -->
            <TextBlock Text="עיצוב" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SettingCard}">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="ערכת נושא:" Foreground="#FFFFFF" Margin="8" />
                    <ComboBox Foreground="#000000" Background="#FFFFFF" Margin="8" x:Name="ThemeCombo">
                        <ComboBoxItem Content="Glass Dark" />
                        <ComboBoxItem Content="Glass Light" />
                    </ComboBox>

                    <CheckBox Content="הפחת תנועה" Foreground="#FFFFFF" Margin="8" />
                </StackPanel>
            </Border>

            <!-- Footer -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,32,0,16">
                <Button Content="שמור" Width="100" Background="#2563EB" Foreground="#FFFFFF" Padding="8" Margin="8" Click="Button_Save" />
                <Button Content="ביטול" Width="100" Background="#333333" Foreground="#FFFFFF" Padding="8" Margin="8" Click="Button_Cancel" />
            </StackPanel>

            <!-- Copyright Footer -->
            <Border Background="#0B1F4D" BorderBrush="#2563EB" BorderThickness="0,1,0,0" Padding="12,12,12,12">
                <TextBlock Text="© 2026 תוכנן ונבנה ע״י גיא רוזנברג - כל הזכויות שמורות"
                           FontSize="10" FontWeight="Bold" Foreground="#4FFF00"
                           TextAlignment="Center"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
